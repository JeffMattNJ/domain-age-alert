<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xsi:type="MailApp">

  <Id>496ca05b-360a-4c88-a01b-c88de16d8f1b</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Domain Age Alert</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Domain Age Alert"/>
  <Description DefaultValue="Alerts you when an email is from a recently registered domain - a top sign of phishing."/>
  <IconUrl DefaultValue="https://JeffMattNJ.github.io/domain-age-alert/icon-80.png" />
  <HighResolutionIconUrl DefaultValue="https://JeffMattNJ.github.io/domain-age-alert/icon-128.png" />
  <SupportUrl DefaultValue="https://JeffMattNJ.github.io/domain-age-alert" />
  <AppDomains>
    <AppDomain>https://JeffMattNJ.github.io</AppDomain>
    <AppDomain>https://rdap.org</AppDomain>
    <AppDomain>https://data.iana.org</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets DefaultMinVersion="1.1">
      <Set Name="Mailbox"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://JeffMattNJ.github.io/domain-age-alert/taskpane.html"/>
        <RequestedHeight>300</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
  </Rule>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.3">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>
    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <FunctionFile resid="Commands.Url"/>
          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="msgReadGroup">
                <Label resid="GroupLabel"/>
                <Control xsi:type="Button" id="msgReadOpenPaneButton">
                  <Label resid="TaskpaneButton.Label"/>
                  <Supertip>
                    <Title resid="TaskpaneButton.Label"/>
                    <Description resid="TaskpaneButton.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="Taskpane.Url"/>
                    <SupportsPinning>true</SupportsPinning>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://JeffMattNJ.github.io/domain-age-alert/icon-16.png"/>
        <bt:Image id="Icon.32x32" DefaultValue="https://JeffMattNJ.github.io/domain-age-alert/icon-32.png"/>
        <bt:Image id="Icon.80x80" DefaultValue="https://JeffMattNJ.github.io/domain-age-alert/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Commands.Url" DefaultValue="https://JeffMattNJ.github.io/domain-age-alert/commands.html"/>
        <bt:Url id="Taskpane.Url" DefaultValue="https://JeffMattNJ.github.io/domain-age-alert/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel" DefaultValue="Security"/>
        <bt:String id="TaskpaneButton.Label" DefaultValue="Domain Age Check"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="TaskpaneButton.Tooltip" DefaultValue="Check when the sender domain was registered. New domains are a top sign of phishing."/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
